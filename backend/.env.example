# ─── latearte - Template de Variables de Entorno ───
# Copia este archivo a .env y completa los valores.

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:pass@localhost:5433/latearte_db?schema=public"

# Cache (Redis)
REDIS_URL="redis://localhost:6379"

# Security (JWT)
JWT_SECRET="generate-a-strong-secret-here"
JWT_EXPIRATION="7d"

# App
PORT=3001
NODE_ENV="development"
